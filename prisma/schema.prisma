// matchmedia.com.bd — Prisma schema (FOUNDATION ONLY)
// Privacy-first nationwide Bangladeshi matrimonial platform.
// Core funnel: browse (blurred photos) -> photo-access request -> interest
//              -> accept -> contact-reveal (paywall).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  GENERAL
  GUARDIAN
  MEDIA
  AGENT
  ADMIN
}

// Which onboarding path the user chose. NULL means they haven't reached
// the category-selection step yet (brand-new signup). The value drives:
//   SELF / PARENTS → single Profile, full matrimonial funnel
//   MEDIA          → multiple Profiles under one account (referredProfiles)
//   AGENT          → no matrimonial Profile; goes straight to admin verification
enum AccountCategory {
  SELF
  PARENTS
  MEDIA
  AGENT
}

enum ImagePrivacy {
  BLURRED
  PUBLIC
}

// Pre-moderation lifecycle for uploaded photos. New photos are PENDING and are
// shown to no one but the owner until an admin APPROVES them.
enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhotoAccessStatus {
  PENDING
  APPROVED
  DENIED
  REVOKED
}

enum InterestStatus {
  SENT
  ACCEPTED
  DECLINED
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
}

// Lifecycle of an admin-initiated verification assignment to an AGENT user.
// PENDING → IN_PROGRESS (agent acknowledges) → SUBMITTED (agent done, awaiting
// review) → VERIFIED (admin approves, Profile.isVerified set true) or CANCELLED.
enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  CANCELLED
}

// Verification lifecycle for a MEDIA agency account.
// UNVERIFIED → PENDING_APPROVAL (agency submits trade license)
//            → VERIFIED (admin approves) or REJECTED (admin rejects)
// REJECTED agencies can re-submit, cycling back to PENDING_APPROVAL.
enum AgencyVerificationStatus {
  UNVERIFIED
  PENDING_APPROVAL
  VERIFIED
  REJECTED
}

// Generic manual-approval status for individual user verifications
// (NID photos, live selfie). Shared by every document type so we don't
// need a new enum per field. REJECTED allows re-submission.
enum VerificationStatus {
  UNVERIFIED  // not yet submitted
  PENDING     // submitted, awaiting admin review
  APPROVED    // admin accepted
  REJECTED    // admin rejected; user may resubmit
}

// --- Billing / subscription -------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// PERCENT: discountValue is 0–100. FIXED: discountValue is an amount in poisha.
enum DiscountType {
  PERCENT
  FIXED
}

// Lets the backend auto-discover the coupon to apply at a lifecycle moment.
enum CouponTrigger {
  NONE
  SIGNUP
  RENEWAL
}

// ---------------------------------------------------------------------------
// Job Board
// ---------------------------------------------------------------------------

enum JobStatus {
  OPEN
  ASSIGNED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum UsageAction {
  PROFILE_VIEW
  PHOTO_REQUEST
}

// --- Trust & safety: user reports ------------------------------------------

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReportReason {
  INAPPROPRIATE_PHOTO
  FAKE_PROFILE
  HARASSMENT
  SPAM
  OTHER
}

// --- Messaging --------------------------------------------------------------

// TEXT now. SYSTEM/CALL_EVENT are reserved so future call invites / missed-call
// notices can log inline into the same thread (WebRTC-ready, no schema change).
enum MessageType {
  TEXT
  SYSTEM
  CALL_EVENT
}

// --- Notifications ----------------------------------------------------------

// The kind of in-app notification, so the UI can pick an icon + localized copy.
enum NotificationType {
  PHOTO_REQUEST // someone requested access to your photo
  PHOTO_ACCESS_GRANTED // an owner approved your photo-access request
  INTEREST_RECEIVED // someone expressed interest in you
  INTEREST_ACCEPTED // your interest was accepted (it's a match)
  NEW_MESSAGE // a matched user sent you a message
  MISSED_CALL // a matched user voice-called you and you didn't answer
  PHOTO_APPROVED // admin approved your uploaded photo
  PHOTO_REJECTED // admin rejected your uploaded photo
  VERIFIED_BADGE // admin granted your Verified trust badge
  REPORT_RESOLVED // a report you filed was actioned
  NID_APPROVED    // admin approved NID submission
  NID_REJECTED    // admin rejected NID submission
  SELFIE_APPROVED // admin approved live selfie
  SELFIE_REJECTED // admin rejected live selfie
}

// --- Voice calling (WebRTC) -------------------------------------------------

// Lifecycle of a 1:1 voice call. RINGING→ACTIVE→ENDED is the happy path; the
// rest capture the ways a call can finish before/without connecting.
enum CallStatus {
  RINGING // caller dialed; awaiting callee answer
  ACTIVE // callee accepted; media flowing
  ENDED // a connected call hung up normally
  MISSED // callee never answered (timeout or caller cancelled)
  DECLINED // callee actively rejected
  CANCELLED // caller aborted before connect (no missed-call alert)
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id               String           @id @default(cuid())
  role             Role             @default(GENERAL)
  // NULL until the user completes Step 1 of the onboarding wizard.
  // Setting this also syncs `role` (MEDIA/AGENT users get the matching Role).
  accountCategory  AccountCategory?
  email            String           @unique
  passwordHash     String
  mobile           String?          @unique
  isMobileVerified Boolean          @default(false)
  // Pro (paid) membership — drives the VIP badge and contact-reveal gate.
  // `isPro` is the denormalized fast-path flag; `proExpiresAt` is the source of
  // truth that isProActive() checks so access lapses the moment it passes.
  isPro            Boolean   @default(false)
  proExpiresAt     DateTime?
  // Agency info — only populated for MEDIA accounts.
  agencyName               String?
  contactPerson            String?
  agencyDistrict           String?
  // Storage key (not a URL) of the agent's profile photo; signed at read time.
  agentAvatarKey           String?
  // Storage key (not a URL) of the agency's logo in Supabase; signed at read time.
  agencyLogo               String?
  // Storage key of the uploaded trade license document.
  tradeLicenseUrl          String?
  agencyVerificationStatus AgencyVerificationStatus @default(UNVERIFIED)

  // Document / identity verification — manual admin-approval workflow.
  // Keys are Supabase Storage paths in the private "verification-docs" bucket;
  // never stored as public URLs (signed at read time, like profile photos).
  nidFrontKey              String?
  nidBackKey               String?
  nidVerificationStatus    VerificationStatus @default(UNVERIFIED)
  nidReviewNote            String?   // admin rejection reason; cleared on re-submit

  selfieKey                String?
  selfieVerificationStatus VerificationStatus @default(UNVERIFIED)
  selfieReviewNote         String?

  createdAt        DateTime  @default(now())

  // 1:1 — the user's own profile
  profile Profile?

  // Profiles a MEDIA user has referred onto the platform
  referredProfiles Profile[] @relation("MediaReferrals")

  // Photo-access requests
  photoRequestsMade     PhotoAccessRequest[] @relation("PhotoRequestsMade")
  photoRequestsReceived PhotoAccessRequest[] @relation("PhotoRequestsReceived")

  // Interests
  interestsSent     Interest[] @relation("InterestsSent")
  interestsReceived Interest[] @relation("InterestsReceived")

  // Guardian-managed wards
  wards WardDetails[] @relation("GuardianWards")

  // Agent service requests
  agentServiceRequests     ServiceRequest[] @relation("AgentServices")
  requestedServiceRequests ServiceRequest[] @relation("RequesterServices")

  // Verification assignments (admin perspective: jobs they created)
  assignmentsCreated   VerificationAssignment[] @relation("AssignmentCreatedBy")
  // Verification assignments (agent perspective: jobs assigned to them)
  assignmentsReceived  VerificationAssignment[] @relation("AssignmentAgent")

  // Profile view activity (as the viewer)
  profileViews ProfileViewLog[] @relation("ViewsMade")

  // Billing / subscription
  orders            Order[]            @relation("UserOrders")
  subscriptions     Subscription[]     @relation("UserSubscriptions")
  couponRedemptions CouponRedemption[] @relation("UserRedemptions")
  dailyUsage        DailyUsage[]       @relation("UserUsage")

  // Trust & safety
  reportsMade     Report[] @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")

  // Messaging
  conversationsA Conversation[] @relation("ConvA")
  conversationsB Conversation[] @relation("ConvB")
  messagesSent   Message[]      @relation("MsgSender")

  // Trust: mobile one-time-password challenges
  mobileOtps MobileOtp[] @relation("UserOtps")

  // In-app notifications (as recipient)
  notifications Notification[] @relation("UserNotifications")

  // Job board
  postedJobs      JobPost[]        @relation("PostedJobs")
  jobApplications JobApplication[] @relation("AgentApplications")
}

model Profile {
  id     String  @id @default(cuid())
  // NULL for agency-managed client profiles whose subject has no login account yet.
  // PostgreSQL allows multiple NULLs in a unique index, so @@unique is safe.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName      String?
  gender        String
  dateOfBirth   DateTime
  // Profile-detail fields are nullable so completion can grow over time
  // (see completionScore, which defaults to 10 for a fresh profile).
  district      String?
  upazila       String?
  profession    String?
  education     String?
  maritalStatus String?
  bio           String?

  // Extended attributes (shown in the "View Full Details" modal)
  height         String?
  weight         String?
  childrenStatus String?
  familyDetails  String?

  // True when this profile was created by a MEDIA agency on behalf of a client
  // who has no User account of their own. Drives the "Managed by Agency" badge.
  managedByAgency Boolean @default(false)

  // Trust badge: ID/photo verified by an admin/agent.
  isVerified      Boolean @default(false)
  nameHidden      Boolean @default(false)
  completionScore Int     @default(10)

  // Referral attribution -> the MEDIA User who brought this profile in
  referredById String?
  referredBy   User?   @relation("MediaReferrals", fields: [referredById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  images                 ProfileImage[]
  viewLogs               ProfileViewLog[]         @relation("ProfileViews")
  serviceRequests        ServiceRequest[]         @relation("ServiceTargets")
  verificationAssignment VerificationAssignment?

  @@index([referredById])
  @@index([district, upazila])
}

model ProfileImage {
  id          String       @id @default(cuid())
  profileId   String
  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  privacy     ImagePrivacy @default(BLURRED)
  originalKey String
  blurredKey  String
  isPrimary   Boolean      @default(false)
  // Stable display order within a profile's gallery (primary aside).
  sortOrder   Int          @default(0)
  // Pre-moderation: PENDING until an admin reviews. Only APPROVED photos are
  // ever served to other viewers (enforced in lib/data/profiles.ts).
  moderationStatus ModerationStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String? // admin User id (audit only; no FK relation)
  rejectionReason  String?
  createdAt   DateTime     @default(now())

  @@index([profileId])
  @@index([moderationStatus])
}

// ---------------------------------------------------------------------------
// Funnel: photo-access -> interest
// ---------------------------------------------------------------------------

model PhotoAccessRequest {
  id          String            @id @default(cuid())
  viewerId    String
  viewer      User              @relation("PhotoRequestsMade", fields: [viewerId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User              @relation("PhotoRequestsReceived", fields: [ownerId], references: [id], onDelete: Cascade)
  status      PhotoAccessStatus @default(PENDING)
  requestedAt DateTime          @default(now())
  respondedAt DateTime?

  @@unique([viewerId, ownerId])
  @@index([ownerId, status])
}

model Interest {
  id         String         @id @default(cuid())
  senderId   String
  sender     User           @relation("InterestsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User           @relation("InterestsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status     InterestStatus @default(SENT)
  createdAt  DateTime       @default(now())

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

// ---------------------------------------------------------------------------
// Role-specific structures
// ---------------------------------------------------------------------------

model WardDetails {
  id            String   @id @default(cuid())
  guardianId    String
  guardian      User     @relation("GuardianWards", fields: [guardianId], references: [id], onDelete: Cascade)
  targetMetrics Json
  createdAt     DateTime @default(now())

  @@index([guardianId])
}

model ServiceRequest {
  id              String        @id @default(cuid())
  agentId         String
  agent           User          @relation("AgentServices", fields: [agentId], references: [id], onDelete: Cascade)
  requesterId     String
  requester       User          @relation("RequesterServices", fields: [requesterId], references: [id], onDelete: Cascade)
  targetProfileId String
  targetProfile   Profile       @relation("ServiceTargets", fields: [targetProfileId], references: [id], onDelete: Cascade)
  status          ServiceStatus @default(PENDING)
  agentShare      Int
  adminShare      Int
  createdAt       DateTime      @default(now())

  @@index([agentId, status])
  @@index([requesterId])
}

// Admin-initiated physical verification job assigned to an AGENT user.
// One assignment per profile (@@unique on profileId): once a profile is being
// verified, it cannot be simultaneously assigned to two agents.
// Fee breakdown: totalFee = agentShare + platformFee (all in poisha, BDT×100).
// Default rates: ৳2,500 total → ৳2,000 agent (80%) + ৳500 platform (20%).
model VerificationAssignment {
  id           String           @id @default(cuid())

  // Admin who created / owns this assignment (audit FK)
  assignedById String
  assignedBy   User             @relation("AssignmentCreatedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  // AGENT user doing the physical verification
  agentId      String
  agent        User             @relation("AssignmentAgent", fields: [agentId], references: [id], onDelete: Restrict)

  // The candidate whose identity is being verified
  profileId    String           @unique
  profile      Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)

  status       AssignmentStatus @default(PENDING)

  // Agent's completion report (filled when status → SUBMITTED)
  agentNote    String?

  // Fee split in poisha (BDT × 100). Snapshot at assignment time so later rate
  // changes never rewrite existing jobs.
  totalFee     Int              @default(250000) // ৳2,500
  agentShare   Int              @default(200000) // ৳2,000
  platformFee  Int              @default(50000)  // ৳500

  assignedAt   DateTime         @default(now())
  startedAt    DateTime?        // set when agent moves to IN_PROGRESS
  submittedAt  DateTime?        // set when agent submits for review
  completedAt  DateTime?        // set when admin marks VERIFIED or CANCELLED
  createdAt    DateTime         @default(now())

  @@index([agentId, status])
  @@index([assignedById])
}

// ---------------------------------------------------------------------------
// Job Board
// ---------------------------------------------------------------------------

model JobPost {
  id               String           @id @default(cuid())
  title            String
  description      String
  targetDistrict   String
  budgetAmount     Int              // in poisha (e.g. 50000 = ৳500)
  status           JobStatus        @default(OPEN)
  postedById       String
  postedBy         User             @relation("PostedJobs", fields: [postedById], references: [id])
  applications     JobApplication[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, targetDistrict])
  @@index([postedById])
}

model JobApplication {
  id                    String            @id @default(cuid())
  jobPostId             String
  jobPost               JobPost           @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  agentId               String
  agent                 User              @relation("AgentApplications", fields: [agentId], references: [id])
  bidAmount             Int               // in poisha (total bid, gross)
  platformFee           Int               // in poisha (20% of bidAmount)
  agentShare            Int               // in poisha (bidAmount - platformFee)
  estimatedDeliveryDays Int
  note                  String?
  status                ApplicationStatus @default(PENDING)
  createdAt             DateTime          @default(now())

  @@unique([jobPostId, agentId])
  @@index([agentId])
}

// ---------------------------------------------------------------------------
// Platform config + analytics
// ---------------------------------------------------------------------------

model AppSettings {
  id                     String   @id @default(cuid())
  visibilityFloorPercent Int      @default(30)
  updatedAt              DateTime @updatedAt
}

model ProfileViewLog {
  id              String   @id @default(cuid())
  viewerId        String
  viewer          User     @relation("ViewsMade", fields: [viewerId], references: [id], onDelete: Cascade)
  viewedProfileId String
  viewedProfile   Profile  @relation("ProfileViews", fields: [viewedProfileId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  createdAt       DateTime @default(now())

  // One row per viewer/profile/day -> enables daily-unique view counting
  @@unique([viewerId, viewedProfileId, date])
  @@index([viewedProfileId, date])
}

// ---------------------------------------------------------------------------
// Billing: plans, coupons, orders, payments, subscriptions
// ---------------------------------------------------------------------------

// DB-stored plan catalog (no hardcoded prices). Money is integer poisha.
model Plan {
  id           String   @id @default(cuid())
  code         String   @unique // "PRO_1M" | "PRO_3M" | "PRO_12M"
  name         String
  durationDays Int
  priceAmount  Int // poisha (e.g. 120000 = 1200 BDT)
  currency     String   @default("BDT")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  orders Order[]
}

// Dynamic discount engine. SIGNUP/RENEWAL triggers let the backend auto-apply.
model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  description    String?
  discountType   DiscountType
  discountValue  Int // PERCENT: 0-100 | FIXED: poisha
  trigger        CouponTrigger @default(NONE)
  appliesToPlan  String? // null = any plan, else Plan.code
  grantsPlanCode String? // SIGNUP coupon: which plan it provisions
  maxRedemptions Int? // global cap (null = unlimited)
  redeemedCount  Int           @default(0)
  perUserLimit   Int?          @default(1)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  redemptions CouponRedemption[]
  orders      Order[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserRedemptions", fields: [userId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // Enforces perUserLimit=1 (the common case) at the DB level.
  @@unique([couponId, userId])
  @@index([userId])
}

model Order {
  id        String @id @default(cuid())
  invoiceNo String @unique // MM-YYYYMMDD-####
  userId    String
  user      User   @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot of the plan at purchase time so later price changes never
  // rewrite billing history.
  planId       String?
  plan         Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  planCode     String
  planName     String
  durationDays Int

  baseAmount     Int // poisha, pre-discount
  discountAmount Int    @default(0) // poisha
  finalAmount    Int // poisha, charged (0 => skip gateway)
  currency       String @default("BDT")

  couponId   String?
  coupon     Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode String? // snapshot

  status    OrderStatus @default(PENDING)
  gateway   String?
  paidAt    DateTime?
  createdAt DateTime    @default(now())

  payments     Payment[]
  subscription Subscription?
  redemption   CouponRedemption?

  @@index([userId, status])
}

model Payment {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway      String
  gatewayTxnId String?
  status       PaymentStatus @default(INITIATED)
  amount       Int // poisha
  rawPayload   Json?
  createdAt    DateTime      @default(now())

  @@index([orderId])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  orderId   String             @unique
  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  planCode  String
  startsAt  DateTime
  endsAt    DateTime
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime           @default(now())

  @@index([userId, endsAt])
  @@index([status, endsAt]) // cron sweep: ACTIVE rows past endsAt
}

// Free-tier daily caps. One row per (user, day, action); upsert+increment.
model DailyUsage {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation("UserUsage", fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime    @db.Date
  action UsageAction
  count  Int         @default(0)

  @@unique([userId, date, action])
  @@index([userId, date])
}

// User-submitted reports surfaced in the admin moderation queue. Targets a User
// (the profile owner); `imageId` optionally pins the report to a specific photo.
model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reporter       User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUserId String
  reportedUser   User         @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  imageId        String? // optional: a specific ProfileImage being reported
  reason         ReportReason
  note           String?
  status         ReportStatus @default(OPEN)
  resolvedById   String? // admin User id (audit only; no FK relation)
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([status, createdAt])
  @@index([reportedUserId])
}

// --- Messaging: 1:1 conversations between matched users ---------------------

// Exactly two participants, stored as a CANONICAL pair (userAId < userBId) so
// the @@unique guarantees one conversation per pair regardless of who started
// it. Conversation is also the natural future home for a CallSession (WebRTC).
model Conversation {
  id            String   @id @default(cuid())
  userAId       String
  userA         User     @relation("ConvA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User     @relation("ConvB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  // Bumped on every send so the inbox can order by most-recent activity.
  lastMessageAt DateTime @default(now())

  messages Message[]
  calls    CallSession[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MsgSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  type           MessageType  @default(TEXT)
  // Set when the recipient has seen it — drives unread counts / read receipts.
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// --- Trust: mobile OTP ------------------------------------------------------

// One-time-password challenge for verifying a user's mobile number. The code is
// only ever stored as a bcrypt hash; `attempts` caps brute-force and `lastSentAt`
// drives the resend cooldown. A fresh row is created on each send; verification
// stamps `consumedAt` so a code can't be reused.
model MobileOtp {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserOtps", fields: [userId], references: [id], onDelete: Cascade)
  mobile    String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  consumedAt DateTime?
  lastSentAt DateTime  @default(now())
  createdAt DateTime  @default(now())

  @@index([userId])
}

// --- Voice calling: WebRTC call sessions ------------------------------------

// One row per voice-call attempt within a conversation. The cuid `id` doubles
// as the Supabase Realtime signaling channel name (`call:{id}`) — unguessable
// and handed only to the two validated participants, so no separate token is
// needed. `callerId` is plain audit (matches actorId/reviewedById convention).
// Status transitions are driven authoritatively by the server (lib/actions/calls.ts);
// connected-call duration = endedAt − startedAt.
model CallSession {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  callerId       String // who initiated (audit only; no FK relation)
  status         CallStatus   @default(RINGING)
  startedAt      DateTime? // set when the callee accepts (ACTIVE)
  endedAt        DateTime? // set on any terminal status
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// --- In-app notifications ---------------------------------------------------

// A single notification for a recipient (`userId`). `actorId` records who
// triggered it (audit only, no FK so a deleted actor never cascades). `link` is
// the in-app route opened on click; `readAt` drives the unread badge. The
// dispatcher (lib/notifications/dispatch.ts) is the only writer.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  actorId   String? // who triggered it (audit only; no FK relation)
  link      String? // in-app route to open on click
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}
