# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/matchmedia?schema=public"

# Auth.js session secret (any long random string).
AUTH_SECRET="change-me"

# Shared secret for the expiry cron endpoint (/api/cron/expire).
# Vercel Cron sends it automatically as `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET="change-me-too"

# Absolute origin, used to build payment-gateway callback URLs.
APP_URL="http://localhost:3000"

# Payment gateway: "sslcommerz" (live BD gateway) or "mock" (local dev only).
PAYMENT_GATEWAY="sslcommerz"

# SSLCommerz store credentials. Defaults below are the PUBLIC sandbox test store;
# replace with your own and set SSLCOMMERZ_SANDBOX="false" to accept real money.
SSLCOMMERZ_STORE_ID="testbox"
SSLCOMMERZ_STORE_PASSWD="qwerty"
SSLCOMMERZ_SANDBOX="true"

# SMS provider for mobile OTP. "mock" (dev: logs the code to the server console)
# or "sslwireless" (live BD gateway). The mock needs no credentials.
SMS_PROVIDER="mock"

# SSL Wireless SMS credentials (only needed when SMS_PROVIDER="sslwireless").
SSLSMS_API_TOKEN="change-me-sms-api-token"
SSLSMS_SID="change-me-sms-sid"
# Override only if your account uses a non-default endpoint.
# SSLSMS_API_URL="https://smsplus.sslwireless.com/api/v3/send-sms"

# Supabase Storage for profile photos. The SERVICE ROLE key is server-only and
# must never be exposed to the browser. Create a PRIVATE bucket (no public read)
# named to match SUPABASE_STORAGE_BUCKET. Find these in Supabase →
# Project Settings → API (URL + service_role key).
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="change-me-service-role-key"
SUPABASE_STORAGE_BUCKET="profile-photos"
