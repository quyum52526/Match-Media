# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/matchmedia?schema=public"

# Auth.js session secret (any long random string).
AUTH_SECRET="change-me"

# Shared secret for the expiry cron endpoint (/api/cron/expire).
# Vercel Cron sends it automatically as `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET="change-me-too"

# Absolute origin, used to build payment-gateway callback URLs.
APP_URL="http://localhost:3000"

# Payment gateway: "sslcommerz" (live BD gateway) or "mock" (local dev only).
PAYMENT_GATEWAY="sslcommerz"

# SSLCommerz store credentials. Defaults below are the PUBLIC sandbox test store;
# replace with your own and set SSLCOMMERZ_SANDBOX="false" to accept real money.
SSLCOMMERZ_STORE_ID="testbox"
SSLCOMMERZ_STORE_PASSWD="qwerty"
SSLCOMMERZ_SANDBOX="true"
