// matchmedia.com.bd — Prisma schema (FOUNDATION ONLY)
// Privacy-first nationwide Bangladeshi matrimonial platform.
// Core funnel: browse (blurred photos) -> photo-access request -> interest
//              -> accept -> contact-reveal (paywall).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  GENERAL
  GUARDIAN
  MEDIA
  AGENT
  ADMIN
}

enum ImagePrivacy {
  BLURRED
  PUBLIC
}

enum PhotoAccessStatus {
  PENDING
  APPROVED
  DENIED
  REVOKED
}

enum InterestStatus {
  SENT
  ACCEPTED
  DECLINED
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
}

// --- Billing / subscription -------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// PERCENT: discountValue is 0–100. FIXED: discountValue is an amount in poisha.
enum DiscountType {
  PERCENT
  FIXED
}

// Lets the backend auto-discover the coupon to apply at a lifecycle moment.
enum CouponTrigger {
  NONE
  SIGNUP
  RENEWAL
}

enum UsageAction {
  PROFILE_VIEW
  PHOTO_REQUEST
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id               String    @id @default(cuid())
  role             Role      @default(GENERAL)
  email            String    @unique
  passwordHash     String
  mobile           String?   @unique
  isMobileVerified Boolean   @default(false)
  // Pro (paid) membership — drives the VIP badge and contact-reveal gate.
  // `isPro` is the denormalized fast-path flag; `proExpiresAt` is the source of
  // truth that isProActive() checks so access lapses the moment it passes.
  isPro            Boolean   @default(false)
  proExpiresAt     DateTime?
  createdAt        DateTime  @default(now())

  // 1:1 — the user's own profile
  profile Profile?

  // Profiles a MEDIA user has referred onto the platform
  referredProfiles Profile[] @relation("MediaReferrals")

  // Photo-access requests
  photoRequestsMade     PhotoAccessRequest[] @relation("PhotoRequestsMade")
  photoRequestsReceived PhotoAccessRequest[] @relation("PhotoRequestsReceived")

  // Interests
  interestsSent     Interest[] @relation("InterestsSent")
  interestsReceived Interest[] @relation("InterestsReceived")

  // Guardian-managed wards
  wards WardDetails[] @relation("GuardianWards")

  // Agent service requests
  agentServiceRequests     ServiceRequest[] @relation("AgentServices")
  requestedServiceRequests ServiceRequest[] @relation("RequesterServices")

  // Profile view activity (as the viewer)
  profileViews ProfileViewLog[] @relation("ViewsMade")

  // Billing / subscription
  orders            Order[]            @relation("UserOrders")
  subscriptions     Subscription[]     @relation("UserSubscriptions")
  couponRedemptions CouponRedemption[] @relation("UserRedemptions")
  dailyUsage        DailyUsage[]       @relation("UserUsage")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName      String?
  gender        String
  dateOfBirth   DateTime
  // Profile-detail fields are nullable so completion can grow over time
  // (see completionScore, which defaults to 10 for a fresh profile).
  district      String?
  upazila       String?
  profession    String?
  education     String?
  maritalStatus String?
  bio           String?

  // Extended attributes (shown in the "View Full Details" modal)
  height         String?
  weight         String?
  childrenStatus String?
  familyDetails  String?

  // Trust badge: ID/photo verified by an admin/agent.
  isVerified      Boolean @default(false)
  nameHidden      Boolean @default(false)
  completionScore Int     @default(10)

  // Referral attribution -> the MEDIA User who brought this profile in
  referredById String?
  referredBy   User?   @relation("MediaReferrals", fields: [referredById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  images          ProfileImage[]
  viewLogs        ProfileViewLog[] @relation("ProfileViews")
  serviceRequests ServiceRequest[] @relation("ServiceTargets")

  @@index([referredById])
  @@index([district, upazila])
}

model ProfileImage {
  id          String       @id @default(cuid())
  profileId   String
  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  privacy     ImagePrivacy @default(BLURRED)
  originalKey String
  blurredKey  String
  isPrimary   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([profileId])
}

// ---------------------------------------------------------------------------
// Funnel: photo-access -> interest
// ---------------------------------------------------------------------------

model PhotoAccessRequest {
  id          String            @id @default(cuid())
  viewerId    String
  viewer      User              @relation("PhotoRequestsMade", fields: [viewerId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User              @relation("PhotoRequestsReceived", fields: [ownerId], references: [id], onDelete: Cascade)
  status      PhotoAccessStatus @default(PENDING)
  requestedAt DateTime          @default(now())
  respondedAt DateTime?

  @@unique([viewerId, ownerId])
  @@index([ownerId, status])
}

model Interest {
  id         String         @id @default(cuid())
  senderId   String
  sender     User           @relation("InterestsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User           @relation("InterestsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status     InterestStatus @default(SENT)
  createdAt  DateTime       @default(now())

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

// ---------------------------------------------------------------------------
// Role-specific structures
// ---------------------------------------------------------------------------

model WardDetails {
  id            String   @id @default(cuid())
  guardianId    String
  guardian      User     @relation("GuardianWards", fields: [guardianId], references: [id], onDelete: Cascade)
  targetMetrics Json
  createdAt     DateTime @default(now())

  @@index([guardianId])
}

model ServiceRequest {
  id              String        @id @default(cuid())
  agentId         String
  agent           User          @relation("AgentServices", fields: [agentId], references: [id], onDelete: Cascade)
  requesterId     String
  requester       User          @relation("RequesterServices", fields: [requesterId], references: [id], onDelete: Cascade)
  targetProfileId String
  targetProfile   Profile       @relation("ServiceTargets", fields: [targetProfileId], references: [id], onDelete: Cascade)
  status          ServiceStatus @default(PENDING)
  agentShare      Int
  adminShare      Int
  createdAt       DateTime      @default(now())

  @@index([agentId, status])
  @@index([requesterId])
}

// ---------------------------------------------------------------------------
// Platform config + analytics
// ---------------------------------------------------------------------------

model AppSettings {
  id                     String   @id @default(cuid())
  subscriptionModeActive Boolean  @default(false)
  visibilityFloorPercent Int      @default(30)
  updatedAt              DateTime @updatedAt
}

model ProfileViewLog {
  id              String   @id @default(cuid())
  viewerId        String
  viewer          User     @relation("ViewsMade", fields: [viewerId], references: [id], onDelete: Cascade)
  viewedProfileId String
  viewedProfile   Profile  @relation("ProfileViews", fields: [viewedProfileId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  createdAt       DateTime @default(now())

  // One row per viewer/profile/day -> enables daily-unique view counting
  @@unique([viewerId, viewedProfileId, date])
  @@index([viewedProfileId, date])
}

// ---------------------------------------------------------------------------
// Billing: plans, coupons, orders, payments, subscriptions
// ---------------------------------------------------------------------------

// DB-stored plan catalog (no hardcoded prices). Money is integer poisha.
model Plan {
  id           String   @id @default(cuid())
  code         String   @unique // "PRO_1M" | "PRO_3M" | "PRO_12M"
  name         String
  durationDays Int
  priceAmount  Int // poisha (e.g. 120000 = 1200 BDT)
  currency     String   @default("BDT")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  orders Order[]
}

// Dynamic discount engine. SIGNUP/RENEWAL triggers let the backend auto-apply.
model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  description    String?
  discountType   DiscountType
  discountValue  Int // PERCENT: 0-100 | FIXED: poisha
  trigger        CouponTrigger @default(NONE)
  appliesToPlan  String? // null = any plan, else Plan.code
  grantsPlanCode String? // SIGNUP coupon: which plan it provisions
  maxRedemptions Int? // global cap (null = unlimited)
  redeemedCount  Int           @default(0)
  perUserLimit   Int?          @default(1)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  redemptions CouponRedemption[]
  orders      Order[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserRedemptions", fields: [userId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // Enforces perUserLimit=1 (the common case) at the DB level.
  @@unique([couponId, userId])
  @@index([userId])
}

model Order {
  id        String @id @default(cuid())
  invoiceNo String @unique // MM-YYYYMMDD-####
  userId    String
  user      User   @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot of the plan at purchase time so later price changes never
  // rewrite billing history.
  planId       String?
  plan         Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  planCode     String
  planName     String
  durationDays Int

  baseAmount     Int // poisha, pre-discount
  discountAmount Int    @default(0) // poisha
  finalAmount    Int // poisha, charged (0 => skip gateway)
  currency       String @default("BDT")

  couponId   String?
  coupon     Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode String? // snapshot

  status    OrderStatus @default(PENDING)
  gateway   String?
  paidAt    DateTime?
  createdAt DateTime    @default(now())

  payments     Payment[]
  subscription Subscription?
  redemption   CouponRedemption?

  @@index([userId, status])
}

model Payment {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway      String
  gatewayTxnId String?
  status       PaymentStatus @default(INITIATED)
  amount       Int // poisha
  rawPayload   Json?
  createdAt    DateTime      @default(now())

  @@index([orderId])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  orderId   String             @unique
  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  planCode  String
  startsAt  DateTime
  endsAt    DateTime
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime           @default(now())

  @@index([userId, endsAt])
  @@index([status, endsAt]) // cron sweep: ACTIVE rows past endsAt
}

// Free-tier daily caps. One row per (user, day, action); upsert+increment.
model DailyUsage {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation("UserUsage", fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime    @db.Date
  action UsageAction
  count  Int         @default(0)

  @@unique([userId, date, action])
  @@index([userId, date])
}
